# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Gemini API key. Powers the Scam Analyser, AI Advisor and Citizen Shield, and
# the cloud read of the banknote serial number (NETRA tries Gemini first, then
# falls back to offline EasyOCR). Leave blank to run fully offline — the
# genuine/counterfeit verdict never depends on it. Key: aistudio.google.com/apikey
GEMINI_API_KEY=

# Spare keys, tried in order when the one above hits its rate limit. Optional —
# leave blank and nothing changes. They only help if each comes from a
# DIFFERENT Google account: keys minted in one project share a single quota, so
# rotating between those buys nothing.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# --- Optional NETRA tuning -------------------------------------------------
# NETRA_GEMINI_MODEL=gemini-2.5-flash   # cheapest tier that reads the serial
# NETRA_GEMINI_TIMEOUT=12               # seconds before falling back to local
# NETRA_DISABLE_CLOUD=1                 # force fully-offline operation
# NETRA_ENABLE_OCR=0                    # disable EasyOCR (faster, no serials)
# NETRA_DISABLE_CLIP=1                  # disable the is-it-a-banknote model
