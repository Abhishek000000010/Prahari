{
  "version": 2,
  "buildCommand": "vite build",
  "functions": {
    "api/*.ts": {
      "includeFiles": "prahari/modules/netra/samples/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
